
# Keep secrets and deployment-only environment variables here.

# Required for LangGraph and mem0 via an OpenAI-compatible API.
OPENAI_COMPATIBLE_API_KEY=
# OpenAI-compatible base URL (default provider endpoint in this repo).
# Change this when using another OpenAI-compatible provider.
OPENAI_COMPATIBLE_BASE_URL=https://openrouter.ai/api/v1

OPENAI_COMPATIBLE_EMBEDDING_MODEL=

# Optional: Exa search/answer provider. If set, web_search uses Exa.
# Otherwise web_search uses Perplexity Sonar via OpenRouter.
EXA_API_KEY=
# Optional: Perplexity/Sonar model override through OpenRouter.
OPENROUTER_WEB_SEARCH_MODEL=

BUSINESS_KNOWLEDGE_ORACLE_MODEL=

# Optional: Langfuse traces for turns, LLM calls, tools, and side-effect summaries.
# Kobo only sends external telemetry when both keys are set.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Optional override. Defaults to https://us.cloud.langfuse.com.
LANGFUSE_BASE_URL=
# Optional trace tag/metadata label. Railway service/environment values are also captured.
LANGFUSE_DEPLOYMENT_TAG=
# Optional Langfuse filter environment. If unset, derived from deploy tag/Railway identity.
LANGFUSE_TRACING_ENVIRONMENT=
LANGFUSE_CONTENT_LEVEL=full_debug

KOBO_DATA_ROOT=

# Optional: Telegram bot
TELEGRAM_BOT_TOKEN=
# Optional but recommended: Telegram webhook secret token validated on /webhook/telegram
TELEGRAM_WEBHOOK_SECRET=
# Optional public base URL for auto webhook registration on startup (cloud deploys)
# Example: https://your-app.up.railway.app
PUBLIC_BASE_URL=
# Railway fallback: if PUBLIC_BASE_URL is empty and RAILWAY_PUBLIC_DOMAIN is present,
# startup auto-configures webhook with https://$RAILWAY_PUBLIC_DOMAIN/webhook/telegram
# Optional: restrict bot access to specific Telegram accounts
# comma-separated usernames (without @), e.g. myusername,altuser
TELEGRAM_ALLOWED_USERNAMES=
# comma-separated numeric Telegram user IDs, e.g. 123456789
TELEGRAM_ALLOWED_USER_IDS=
# Optional generic owner id for dashboard deployments before Telegram numeric id is known.
# With exactly one TELEGRAM_ALLOWED_USERNAMES value, first message from that username binds its numeric id here.
KOBO_OWNER_CUSTOMER_ID=
# Optional: trusted support operators who can bind to customer tenants
# comma-separated usernames (without @)
TELEGRAM_SUPPORT_USERNAMES=
# comma-separated numeric Telegram user IDs
TELEGRAM_SUPPORT_USER_IDS=

# Optional: Composio Tool Router integration for external SaaS auth/tool access
COMPOSIO_API_KEY=

# Optional: Browser Use Cloud hosted browsers.
# Recommended for browser tasks that benefit from Browser Use Cloud profiles,
# live owner handoff URLs, proxying, and managed browser infrastructure.
BROWSER_USE_API_KEY=

# Optional: CapSolver CAPTCHA solving for Browser Use.
# Disabled unless this key is set. Supports reCAPTCHA v2/v3 and Cloudflare Turnstile.
CAPSOLVER_API_KEY=
